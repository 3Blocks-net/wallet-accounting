// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model SyncState {
  id           String   @id @default(cuid())
  source       String   @unique
  lastBlock    String?
  lastSyncedAt DateTime @default(now()) @updatedAt
}

model Transaction {
  txId       String     @id
  date       DateTime
  sourceType String
  kind       String

  network    String

  feeAsset      String?
  feeAmount     String?
  priceUsd      String?
  valueUsd      String?
  priceEur      String?
  valueEur      String?

  feePayerAddress String?
  feePayer        String?

  note       String?

  transfers  Transfer[]
}

model Transfer {
  id            String @id @default(cuid())
  asset         String
  amount        String
  from          String
  sender        String?
  to            String
  receiver      String?

  direction     String

  operation     String?
  note          String?

  priceUsd      String
  valueUsd      String
  priceEur      String
  valueEur      String

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [txId], onDelete: Cascade)

  @@unique([transactionId, asset, amount, from, to])
}