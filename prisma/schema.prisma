// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SyncState {
  id           String   @id @default(cuid())
  source       String   @unique
  lastBlock    String?
  lastSyncedAt DateTime @default(now()) @updatedAt
}

model Transaction {
  txId       String   @id
  date       DateTime
  sourceType String
  kind       String

  network String

  feeAsset  String?
  feeAmount String?
  priceUsd  String?
  valueUsd  String?
  priceEur  String?
  valueEur  String?

  feePayerAddress String?
  feePayer        String?

  note   String?
  isSpam Boolean @default(false)

  transfers Transfer[]
}

model SpamToken {
  id              String   @id @default(cuid())
  /// Eindeutiger Schlüssel — entspricht dem Cache-Key im PriceService:
  /// ERC20:   "bnb-mainnet:0x55d398..."
  /// Native:  "SYMBOL:ETH"
  tokenKey        String   @unique
  status          String   @default("SPAM") // "SPAM" | "WHITELISTED"
  symbol          String?
  network         String?
  contractAddress String?
  note            String?
  firstSeenAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TokenPrice {
  tokenKey String
  date     String  // "YYYY-MM-DD"
  priceUsd Float

  @@id([tokenKey, date])
}

model Transfer {
  id       String  @id @default(cuid())
  asset    String
  amount   String
  from     String
  sender   String?
  to       String
  receiver String?

  direction    String
  tokenAddress String?

  operation String?
  note      String?

  priceUsd String
  valueUsd String
  priceEur String
  valueEur String

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [txId], onDelete: Cascade)

  @@unique([transactionId, asset, amount, from, to])
}
